[41.791380019022746, "o", "\u001b[35;4H\u001b[38;5;60m\u001b[48;5;232m\u2b1d\u2b1d\u001b[38;5;75m\u25a0\u25a0\u001b[38;5;61m\u25a0\u001b[38;5;239m\u25a0\u001b[38;5;237m\u25a0\u001b[38;5;235m\u25a0\u001b[31;6H\u001b(B\u001b[m\u001b[5A\u001b[38;5;244m\u001b[48;5;232m\u2190 Edit README.md \u001b[38;5;231m  \u001b[31;6H\u001b(B\u001b[m\u001b[1;8H\u001b[38;5;246m\u001b[48;5;235m26\u001b[38;5;168m -\u001b[38;5;231m \u001b[38;5;114m\u001b[48;5;236m\"         LEFT / RIGHT : steer your ship                 \"\u001b[38;5;255m,\u001b[2;7H\u001b[38;5;231m\u001b[48;5;235m \u001b[38;5;246m27\u001b[38;5;168m -\u001b[38;5;231m \u001b[38;5;114m\u001b[48;5;236m\"         UP / DOWN    : move forward / backward         \"\u001b[38;5;255m,\u001b[38;5;231m         \u001b[3;7H\u001b[48;5;235m \u001b[38;5;246m26\u001b[38;5;150m +\u001b[38;5;231m \u001b[38;5;114m\u001b[48;5;236m\"         LEFT / RIGHT : steer your ship    (h / l)     \"\u001b[38;5;255m,\u001b[38;5;231m          \u001b[4;7H\u001b[48;5;235m \u001b[38;5;246m27\u001b[38;5;150m +\u001b[38;5;231m \u001b[38;5;114m\u001b[48;5;236m\"         UP / DOWN    : move forward / back (k / j)     \"\u001b[38;5;255m,\u001b[38;5;231m         \u001b[5;8H\u001b[38;5;246m\u001b[48;5;233m28\u001b[38;5;231m \u001b[2C\u001b[38;5;114m\"         SPACE        : fire                            \"\u001b[38;5;255m,\u001b[6;8H\u001b[38;5;246m29\u001b[38;5;231m \u001b[2C\u001b[38;5;114m\"         P            : pause                           \"\u001b[38;5;255m,\u001b[38;5;231m      \u001b[7;8H\u001b[38;5;246m30\u001b[3C\u001b[38;5;114m\"         Q            : quit                            \"\u001b[38;5;255m,\u001b[8;3H\u001b[38;5;232m\u2503\u001b[38;5;231m    \u001b[38;5;246m31\u001b[38;5;231m   \u001b[38;5;114m\"                                                         \"\u001b[38;5;255m,\u001b[38;5;231m        \u001b[10;3H\u001b[48;5;232m                                                                              \u001b[12;6H\u001b[38;5;244m\u001b[48;5;233m\u2190 Edit README.md\u001b[38;5;231m                                                    \u001b[13;8H  \u001b[3C                                                            \u001b[14;9H\u001b[38;5;246m0\u001b[3C\u001b[38;5;255m## Controls\u001b[38;5;231m                                                \u001b[15;9H\u001b[38;5;246m1\u001b[3C\u001b[38;5;231m                                                            \u001b[16;7H \u001b[38;5;246m22\u001b[38;5;231m   \u001b[38;5;255m| Key          | Action               |\u001b[38;5;231m                             \u001b[17;7H \u001b[38;5;246m23\u001b[38;5;231m   \u001b[38;5;255m|--------------|----------------------|\u001b[38;5;231m                             \u001b[18;7H\u001b[48;5;235m \u001b[?25l\u001b(B\u001b[m\u001b[38;5;246m\u001b[48;5;235m24\u001b[38;5;168m -\u001b[38;5;231m \u001b[38;5;255m\u001b[48;5;236m| `\u2190` / `\u2192`    | Move the ship        |\u001b[38;5;231m                             \u001b[19;7H\u001b[48;5;235m \u001b[38;5;246m25\u001b[38;5;168m -\u001b[38;5;231m \u001b[38;5;255m\u001b[48;5;236m| `\u2191` / `\u2193`    | Move forward / backward |\u001b[38;5;231m                          \u001b[20;7H\u001b[48;5;235m \u001b[38;5;246m24\u001b[38;5;150m +\u001b[38;5;231m \u001b[38;5;255m\u001b[48;5;236m| `\u2190` / `\u2192` or `h` / `l` | Move the ship |\u001b[38;5;231m                          \u001b[21;7H\u001b[48;5;235m \u001b[38;5;246m25\u001b[38;5;150m +\u001b[38;5;231m \u001b[38;5;255m\u001b[48;5;236m| `\u2191` / `\u2193` or `k` / `j` | Move forward / backward |\u001b[38;5;231m                \u001b[22;8H\u001b[38;5;246m\u001b[48;5;233m26\u001b[3C\u001b[38;5;255m| `space`      | Fire                 |\u001b[38;5;231m                    \u001b[23;8H\u001b[38;5;246m27\u001b[3C\u001b[38;5;255m| `p`          | Pause / resume       |\u001b[38;5;231m                     \u001b[24;8H\u001b[38;5;246m28\u001b[3C\u001b[38;5;255m| `q`          | Quit                 |\u001b[25;3H\u001b[38;5;232m\u250