[23.452040633277715, "o", "\u001b[35;4H\u001b[38;5;239m\u001b[48;5;232m\u25a0\u001b[38;5;237m\u25a0\u001b[38;5;235m\u25a0\u001b[38;5;60m\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u001b[31;6H\u001b(B\u001b[m\u001b[35;4H\u001b[38;5;237m\u001b[48;5;232m\u25a0\u001b[38;5;235m\u25a0\u001b[38;5;60m\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u001b[31;6H\u001b(B\u001b[m"]
[23.50438905309744, "o", "\u001b[1;3H\u001b[38;5;231m\u001b[48;5;232m                                                                              \u001b[2;3H\u001b[38;5;232m\u001b[48;5;233m\u2503\u001b[38;5;231m                                                                             \u001b[3;6H\u001b[38;5;244m# Verify difficulty scaling\u001b[4;6H\u001b[38;5;231m                           \u001b[5;6H\u001b[38;5;255m$ python3 -c \"\u001b[6;6Hfrom shooter.spawner import SpawnPolicy\u001b[7;6Hsp =\u001b[CSpawnPolicy(cols=80, seed=0, base_interval=20, base_speed=4)\u001b[8;6Hassert sp._interval =\u001b[C 20\u001b[Cand sp._spe\u001b[Cd == 4\u001b[38;5;231m                     \u001b[9;6H\u001b[38;5;255msp.scale(0)\u001b[38;5;231m                                 \u001b[10;6H\u001b[38;5;255massert sp._interval == 20 and sp._speed == 4\u001b[11;6Hsp.scale(25)\u001b[38;5;231m                                \u001b[12;6H\u001b[38;5;255m# 25 points => 1 step => interval *= 0.85, speed /= 1.10\u001b[13;6Hassert sp._interval == int(20 * 0.85), sp._int\u001b[Crval\u001b[38;5;231m     \u001b[14;6H\u001b[38;5;255m# \u001b[Cpeed /= 1.10 => 4/1.10 = 3.636\u001b[C.. => round = 4, but base_speed/1.10 = 3.\u001b[15;6H63 -> round = 4\u001b[38;5;231m                                                            \u001b[16;6H\u001b[38;5;255mprint('1 step:', sp._interval, sp._speed)\u001b[17;6Hsp.scale(100)\u001b[38;5;231m                            \u001b[18;6H\u001b[38;5;255mprint('4 steps:', sp._interval, sp._speed)\u001b[19;13Hscal\u001b[C \u001b[Cmoke OK')\u001b[38;5;231m                   \u001b[20;6H\u001b[38;5;255m\"\u001b[38;5;231m                      \u001b[21;6H \u001b[22;6H\u001b[38;5;255m1 step: 17 4\u001b[23;6H4\u001b[5Cs: 10 3\u001b[24;6Hscal\u001b[C \u001b[Cmoke\u001b[COK\u001b[25;6H\u001b[38;5;231m              \u001b[26;3H\u001b[48;5;232m   \u001b[38;5;255m~ Preparing edit...\u001b[38;5;231m                                                        \u001b[31;6H\u001b(B\u001b[m\u001b[1;3H\u001b[38;5;232m\u001b[48;5;233m\u2503\u001b[38;5;231m                                                                             \u001b[2;6H\u001b[38;5;244m# Verify difficulty scaling\u001b[3;6H\u001b[38;5;231m                           \u001b[4;6H\u001b[38;5;255m$ python3 -c \"\u001b[5;6Hfrom shooter.spawner import SpawnPolicy\u001b[6;6Hsp =\u001b[CSpawnPolicy(cols=80, seed=0, base_interval=20, base_speed=4)\u001b[7;6Hassert sp._interval =\u001b[C 20\u001b[Cand sp._spe\u001b[Cd == 4\u001b[38;5;231m                     \u001b[8;6H\u001b[38;5;255msp.scale(0)\u001b[38;5;231m                                 \u001b[9;6H\u001b[38;5;255massert sp._interval == 20 and sp._speed == 4\u001b[10;6Hsp.scale(25)\u001b[38;5;231m                                \u001b[11;6H\u001b[38;5;255m# 25 points => 1 step => interval *= 0.85, speed /= 1.10\u001b[12;6Hassert sp._interval == int(20 * 0.85), sp._int\u001b[Crval\u001b[38;5;231m     \u001b[13;6H\u001b[38;5;255m# \u001b[Cpeed /= 1.10 => 4/1.10 = 3.636\u001b[C.. => round = 4, but base_speed/1.10 = 3.\u001b[14;6H63 -> round = 4\u001b[38;5;231m                                                            \u001b[15;6H\u001b[38;5;255mprint('1 step:', sp._interval, sp._speed)\u001b[16;6Hsp.scale(100)\u001b[38;5;231m                            \u001b[17;6H\u001b[38;5;255mprint('4 steps:', sp._interval, sp._speed)\u001b[18;13Hscal\u001b[C \u001b[Cmoke OK')\u001b[38;5;231m                   \u001b[19;6H\u001b[38;5;255m\"\u001b[38;5;231m                      \u001b[20;6H \u001b[21;6H\u001b[38;5;255m1 step: 17 4\u001b[22;6H4\u001b[5Cs: 10 3\u001b[23;6Hscal\u001b[C \u001b[Cmoke\u001b[COK\u001b[24;6H\u001b[38;5;231m              \u001b[25;3H\u001b[48;5;232m                                                                              \u001b[35;4H\u001b[38;5;235m\u25a0\u001b[38;5;60m\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u001b[31;6H\u001b(B\u001b[m\u001b[35;4H\u001b[38;5;60m\u001b[48;5;232m\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u2b1d\u001b[31;6H\u001b(B\u001b[m"]
