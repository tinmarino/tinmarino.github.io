[3.815060308135799, "o", "\u001b[36;1H\u001b[38;5;223m\u001b[48;5;235m60 more lines\u001b[38;5;251m\u001b[C\u001b[K\u001b[?25l\u001b(B\u001b[m\u001b[2;63H\u001b[38;5;242m\u001b[48;5;235m  1 \u001b[38;5;251m\u001b[K\u001b[3;63H\u001b[38;5;214m\u001b[48;5;237m  2 \u001b[38;5;108m\u001b[4m* [ ] \u001b[38;5;223mCreate a Python 3.11+ project skeleton: `\u001b[38;5;108mshooter.   \u001b[4;63H\u001b(B\u001b[m\u001b[38;5;214m\u001b[48;5;237m    \u001b[38;5;108m\u001b[4mpy\u001b[38;5;223m`, `\u001b[38;5;108mshooter/\u001b[38;5;223m`                                           \u001b[5;63H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m  3 \u001b[38;5;223m      package with \u001b[38;5;108m__init__.py\u001b[38;5;223m, \u001b[38;5;108mREADME.md\u001b[38;5;223m,            \u001b[38;5;251m\u001b[K\u001b[6;63H\u001b[38;5;242m    \u001b[38;5;108mrequirements.txt\u001b[38;5;251m\u001b[K\u001b[7;63H\u001b[38;5;242m  4 \u001b[38;5;223m      (no runtime deps; \u001b[38;5;108mpytest\u001b[38;5;223m in a \u001b[38;5;108mrequirements-dev.  \u001b[38;5;251m\u001b[K\u001b[8;63H\u001b[38;5;242m    \u001b[38;5;108mtxt\u001b[38;5;223m).\u001b[38;5;251m\u001b[K\u001b[9;63H\u001b[38;5;242m  5 \u001b[38;5;108m* [ ] \u001b[38;5;223mAdd a \u001b[38;5;108mMakefile\u001b[38;5;223m with \u001b[38;5;108mmake run\u001b[38;5;223m, \u001b[38;5;108mmake test\u001b[38;5;223m,      \u001b(B\u001b[m\u001b[38;5;251m\u001b[48;5;235m\u001b[K\u001b[10;63H\u001b[38;5;242m    \u001b[38;5;108mmake lint\u001b[38;5;251m\u001b[K\u001b[11;63H\u001b[38;5;242m  6 \u001b[38;5;223m      targets so the recording always uses the same       \u001b[12;63H\u001b[38;5;242m    \u001b[38;5;223mentrypoints.\u001b[38;5;251m\u001b[K\u001b[13;63H\u001b[38;5;242m  7 \u001b[38;5;108m* [ ] \u001b[38;5;223mInitialise the curses screen in \u001b[38;5;108mshooter/display.   \u001b[38;5;251m\u001b[K\u001b[14;63H\u001b[38;5;242m    \u001b[38;5;108mpy\u001b[38;5;223m:\u001b[38;5;251m\u001b[K\u001b[15;63H\u001b[38;5;242m  8 \u001b[38;5;223m     