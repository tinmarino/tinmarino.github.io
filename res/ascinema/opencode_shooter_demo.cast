[3.161490385859785, "o", "\r\u001b[38;5;242m\u001b[48;5;235m 41 \u001b[38;5;108m\u001b[48;5;59m\u001b[7m*\u001b[5C\u001b[38;5;223mIntroduce difficulty ramping: every 25 points,     \r\n\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m    \u001b[38;5;223m\u001b[48;5;59m\u001b[7mincrease \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m       \u001b[4;2H\u001b[38;5;242m4\u001b[2C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      asteroid spawn rate by 15% and speed by 10%. \u001b[5;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m43\u001b[C\u001b[38;5;108m\u001b[48;5;59m\u001b[7m* [ ] \u001b[38;5;223mShow a Game Over screen with final score, a \"Press \u001b[6;3H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m \u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7mR to \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m                                                 \u001b[7;2H\u001b[38;5;242m44\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      restart / Q to quit\" hint, and a framed box drawn  \u001b[8;3H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m \u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7mwith box \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m                                     \u001b[9;2H\u001b[38;5;242m45\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      characters. \u001b[10;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m46\u001b[C\u001b[38;5;108m\u001b[48;5;59m\u001b[7m* [ ] \u001b[38;5;223mSupport a `\u001b[38;5;108m--seed\u001b[38;5;223m` CLI flag (argparse) for         \u001b[11;5Hdeterministic demos; \u001b[?25l\u001b(B\u001b[m\u001b[12;2H\u001b[38;5;242m\u001b[48;5;235m47\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      use it in the recording so the asteroid pattern is \u001b[13;5Hreproducible. \u001b[14;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m48\u001b[C\u001b[38;5;108m\u001b[48;5;59m\u001b[7m* [ ] \u001b[38;5;223mPackage the CLI through a thin `\u001b[38;5;108mshooter.py\u001b[38;5;223m` shim   \u001b[15;5Hthat sets \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m    \u001b[16;2H\u001b[38;5;242m49\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      `\u001b[38;5;108mPYTHON_ARGCOMPLETE_OK\u001b[38;5;223m`, appends its directory to  \u001b[17;5H`\u001b[38;5;108msys.path\u001b[38;5;223m`, \u001b[18;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m50\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      then calls `\u001b[38;5;108mshooter.run:main()\u001b[38;5;223m` \u2014 same pattern as \u001b[19;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m51\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      `\u001b[38;5;108m~/Software/Pentest/libreriactf/lctf.py\u001b[38;5;223m`. \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m      \u001b[20;2H\u001b[38;5;242m52\u001b[C\u001b[38;5;108m\u001b[48;5;59m\u001b[7m* [ ] \u001b[38;5;223mAdd unit tests in `\u001b(B\u001b[m\u001b[38;5;108m\u001b[48;5;59m\u001b[7mtests/test_entities.py\u001b[38;5;223m`:        \u001b[21;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m  \u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m`\u001b[38;5;108mPlayer.move\u001b[38;5;223m` \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m                                     \u001b[22;2H\u001b[38;5;242m53\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      clamps inside the viewport, `\u001b[38;5;108mBullet\u001b[38;5;223m` dies at row   \u001b[23;5H0, collisions \u001b[24;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m54\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      trigger on overlap. \u001b[25;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m55\u001b[C\u001b[38;5;108m\u001b[48;5;59m\u001b[7m* [ ] \u001b[38;5;223mAdd `\u001b[38;5;108mmake lint\u001b[38;5;223m` with `\u001b[38;5;108mpylint shooter tests\u001b[38;5;223m`; fix   \u001b[26;5Hevery warning \u001b[27;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m56\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      except intentional ones (attach a `\u001b[38;5;108m# -- pylint:    \u001b[28;5Hdisable=...\u001b[38;5;223m` \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m   \u001b[29;2H\u001b[38;5;242m57\u001b(B\u001b[m\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      comment explaining why). \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m                     \u001b[30;2H\u001b[38;5;242m58\u001b[C\u001b[38;5;108m\u001b[48;5;59m\u001b[7m* [ ] \u001b[38;5;223mFinal polish: write a 15-line ASCII-art banner     \u001b[31;2H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m  \u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7mshown for 3s at \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m           \u001b[32;2H\u001b[38;5;242m59\u001b[C\u001b[38;5;223m\u001b[48;5;59m\u001b[7m      startup, update `\u001b[38;5;108mREADME.md\u001b[38;5;223m` with a GIF reference   \u001b[33;5Hand a run \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m       \r\n\u001b[38;5;214m\u001b[48;5;237m 60 \u001b[38;5;223m\u001b[48;5;59m\u001b[7m      \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235mr\u001b[48;5;59m\u001b[7mecipe, and cut a git tag `\u001b[38;5;108mv0.1.0\u001b[38;5;223m`. \u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;235m               \u001b[35;2H\u001b[38;5;239m\u001b[48;5;223m\u001b[7m    ~/Software/Python/AI/DemoShooter/doc/idea.mdBot  7,60\u001b[34;11H\u001b[?12l\u001b[?25h\u001b(B\u001b[m"]
