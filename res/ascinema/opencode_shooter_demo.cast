[45.72885998540061, "o", "\u001b[2;1H\u001b[38;5;223m\u001b[48;5;235m\u25bd\r  \r\n           \u001b[H\u001b(B\u001b[m\u001b[38;5;214m\u001b[48;5;237m  1 \u001b[38;5;223m\u001b[4m#\u001b[38;5;174m\u001b[1m Shooter\u001b(B\u001b[m\u001b[38;5;223m\u001b[48;5;237m\u001b[4m                                                                                                               \u001b[2;1H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m  2 \u001b[38;5;251m\u001b[K\r\n\u001b[38;5;242m  3 \u001b[38;5;223mTerminal space shooter rendered with \u001b[38;5;108mcurses\u001b[38;5;223m. Python 3.11+, no\u001b[38;5;251m\u001b[K\r\n\u001b[38;5;242m  4 \u001b[38;5;223mruntime dependencies (only \u001b[38;5;108mpytest\u001b[38;5;223m / \u001b[38;5;108mpylint\u001b[38;5;223m for development).\r\n\u001b[38;5;242m  5 \r\n  6 \u001b[38;5;108m\u001b[4mdemo\r\n\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m  7 \r\n  8 \u001b[38;5;223m##\u001b[38;5;114m\u001b[1m Run\r\n\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m  9 \r\n 10 \u001b[38;5;108m```bash\r\n\u001b[38;5;242m 11 \u001b[38;5;223m./shooter.py\r\n\u001b[38;5;242m 12 \u001b[38;5;108m```\r\n\u001b[38;5;242m 13 \r\n 14 \u001b[38;5;223mReproducible demos:\r\n\u001b[38;5;242m 15 \r\n 16 \u001b[38;5;108m```bash\r\n\u001b[38;5;242m 17 \u001b[38;5;223m./shooter.py \u001b[38;5;208m--seed\u001b[38;5;223m \u001b[38;5;175m42\r\n\u001b[38;5;242m 18 \u001b(B\u001b[m\u001b[38;5;108m\u001b[48;5;235m```\r\n\u001b[38;5;242m 19 \r\n 20 \u001b[38;5;223m##\u001b[38;5;114m\u001b[1m Controls\r\n\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m 21 \r\n 22 \u001b[38;5;223m| Key\u001b[10C| Action\u001b[15C|\r\n\u001b[38;5;242m 23 \u001b[38;5;223m|--------------|----------------------|\r\n\u001b[38;5;242m 24 \u001b[38;5;223m| `\u2190` / `\u2192` or `h` / `l` | Move the ship |\r\n\u001b[38;5;242m 25 \u001b[38;5;223m| `\u2191` / `\u2193` or `k` / `j` | Move forward / backward |\r\n\u001b[38;5;242m 26 \u001b[38;5;223m| `space`      | Fire\u001b[17C|\r\n\u001b[38;5;242m 27 \u001b[38;5;223m| `p`\u001b[10C| Pause / resume\u001b[7C|\r\n\u001b[38;5;242m 28 \u001b[38;5;223m| `q`\u001b[10C| Quit\u001b[17C|\r\n\u001b[38;5;242m 29 \u001b[38;5;223m| `r`\u001b[10C| Restart (after game-over) |\r\n\u001b[38;5;242m 30 \r\n 31 \u001b[38;5;223m##\u001b[38;5;114m\u001b[1m Develop\r\n\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m 32 \r\n 33 \u001b[38;5;108m```bash\r\n\u001b[38;5;242m 34 \u001b[38;5;223mmake \u001b[38;5;203mtest\u001b[8C\u001b[38;5;244m# pytest\r\n\u001b[38;5;239m\u001b[48;5;223m\u001b[7mREADME.md    ~/Software/Python/AI/DemoShooter/README.md                                                          Top  1,1/57\u001b[1;5H\u001b[?12l\u001b[?25h\u001b(B\u001b[m\u001b]0;[41] README.md (~/Software/Python/AI/DemoShooter) - VIM\u0007\u001b[?25l\u001b[?12l\u001b[?25h"]
[45.907126387814216, "o", "\u001b[38;5;251m\u001b[48;5;235m\u001b[1;34r\u001b[1;1H\u001b[17M\u001b[1;1H\u001b[38;5;214m\u001b[48;5;237m 18 \u001b[38;5;108m\u001b[4m```\u001b[38;5;223m                                                                                                                     \u001b[18;1H\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m 35 \u001b[38;5;223mmake lint\u001b[8C\u001b[38;5;244m# pylint 10/10\r\n\u001b[38;5;242m 36 \u001b[38;5;223mmake run\u001b[9C\u001b[38;5;244m# play the game\r\n\u001b[38;5;242m 37 \u001b[38;5;108m```\r\n\u001b[38;5;242m 38 \r\n 39 \u001b[38;5;223m##\u001b[38;5;114m\u001b[1m Layout\r\n\u001b(B\u001b[m\u001b[38;5;242m\u001b[48;5;235m 40 \r\n 41 \u001b[38;5;108m```\r\n\u001b[38;5;242m 42 \u001b[38;5;108mshooter.py            # thin CLI shim (PYTHON_ARGCOMPLETE_OK)\r\n\u001b[38;5;242m 43 \u001b[38;5;108mshooter/\r\n\u001b[38;5;242m 44 \u001b[38;5;108m  run.py              # argparse dispatcher\r\n\u001b[38;5;242m 45 \u001b[38;5;108m  game.py             # fixed-timestep loop\r\n\u001b[38;5;242m 46 \u001b[38;5;108m  display.py          # curses context manager\r\n\u001b[38;5;242m 47 \u001b[1;37r\u001b[30;5H\u001b[?25l\u001b(B\u001b[m\u001b[38;5;108m\u001b[48;5;235m  colors.py           # named color pairs with mono-color fallback\r\n\u001b[38;5;242m 48 \u001b[38;5;108m  entities.py         # Player, Bullet, Asteroid\r\n\u001b[38;5;242m 49 \u001b[38;5;108m  spawner.py          # SpawnPolicy with seeded RNG\r\n\u001b[38;5;242m 50 \u001b[38;5;108m  collisions.py       # bullet/player vs asteroid\r\n\u001b[38;5;242m 51 \u001b[38;5;108m  hud.py              # score / lives / level banner\u001b[35;113H\u001b[38;5;239m\u001b[48;5;223m\u001b[7m73%  1,18\u001b(B\u001b[m\u001b[38;5;251m\u001b[48;5;235m\r\n\u001b[K\u001b[1;5H\u001b[?12l\u001b[?25h\u001b(B\u001b[m"]
