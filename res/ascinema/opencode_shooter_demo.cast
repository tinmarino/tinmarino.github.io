[21.857913605905082, "o", "\u001b[1;8H\u001b[38;5;246m\u001b[48;5;233m122\u001b[3C\u001b[38;5;244m\u001b[3m# Resolve player vs asteroid hits; each hit costs a life and \u001b[2;3H\u001b(B\u001b[m\u001b[38;5;232m\u001b[48;5;233m\u2503\u001b[38;5;231m          \u001b[38;5;244m\u001b[3mtriggers a flash\u001b(B\u001b[m\u001b[38;5;231m\u001b[48;5;233m                                                   \u001b[3;3H\u001b[38;5;232m\u2503\u001b[38;5;231m    \u001b[38;5;246m123\u001b[38;5;231m   \u001b[38;5;168mdamage\u001b[38;5;255m \u001b[38;5;73m=\u001b[38;5;255m \u001b[38;5;216mplayer_hits\u001b[38;5;255m(\u001b[38;5;168mstate\u001b[38;5;255m.\u001b[38;5;168mplayer\u001b[38;5;255m, \u001b[38;5;168mstate\u001b[38;5;255m.\u001b[38;5;168masteroids\u001b[38;5;255m)\u001b[38;5;231m                \u001b[4;3H\u001b[38;5;232m\u2503\u001b[38;5;231m    \u001b[38;5;246m124\u001b[38;5;231m   \u001b[38;5;140m\u001b[3mif\u001b(B\u001b[m\u001b[38;5;255m\u001b[48;5;233m \u001b[38;5;168mdamage\u001b[38;5;255m:\u001b[38;5;231m                                                         \u001b[5;3H\u001b[38;5;232m\u2503\u001b[38;5;231m                                                                             \u001b[7;3H\u001b[38;5;232m\u2503\u001b[38;5;231m                                                                             \u001b[8;3H\u001b[38;5;232m\u2503\u001b[38;5;231m  \u001b[38;5;244m\u280b\u001b[38;5;231m \u001b[38;5;244mVerify difficulty scaling\u001b[38;5;231m                                                \u001b[9;3H\u001b[38;5;232m\u2503\u001b[38;5;231m                                                                             \u001b[10;6H\u001b[38;5;255m$ python3 -c \"\u001b[11;6Hfrom shooter.spawner import SpawnPolicy\u001b[12;6Hsp = SpawnPolicy(cols=80, seed=0, base_interval=20, base_speed=4)\u001b[13;6Hassert sp._interval == 20 and sp._speed == 4\u001b[38;5;231m                              \u001b[14;6H\u001b[38;5;255msp.scale(0)\u001b[38;5;231m                                                \u001b[15;6H\u001b[38;5;255massert sp._interval == 20 and sp._speed == 4\u001b[16;6Hsp.scale(25)\u001b[38;5;231m                    \u001b[17;6H\u001b[38;5;255m# 25 points => 1 step => interval *= 0.85, speed /= 1.10\u001b[38;5;231m                   \u001b[18;6H\u001b[38;5;255massert sp._interval == int(20 * 0.85), sp._interval\u001b[38;5;231m                        \u001b[19;6H\u001b[38;5;255m# speed /= 1.10 => 4/1.10 = 3.636... => round = 4, but base_speed/1.10 = 3.\u001b[20;6H63 -> round = 4\u001b[38;5;231m            \u001b[?25l\u001b(B\u001b[m\u001b[38;5;231m\u001b[48;5;233m                                          \u001b[21;6H\u001b[38;5;255mprint('1 step:', sp._interval, sp._speed)\u001b[22;6Hsp.scale(100)\u001b[38;5;231m                                              \u001b[23;6H\u001b[38;5;255mprint('4 steps:', sp._interval, sp._speed)\u001b[24;6Hprint('scale smoke OK')\u001b[25;3H\u001b[38;5;232m\u2503\u001b[38;5;231m  \u001b[38;5;255m\"\u001b[38;5;231m                                                                          \u001b[26;3H\u001b[38;5;232m\u2503\u001b[38;5;231m                                                                             \u001b[31;6H\u001b[?12l\u001b[?25h\u001b[1 q\u001b(B\u001b[m\u001b[35;4H\u001b[38;5;75m\u001b[48;5;232m\u25a0\u001b[38;5;61m\u25a0\u001b[38;5;239m\u25a0\u001b[38;5;237m\u25a0\u001b[38;5;235m\u25a0\u001b[38;5;61m\u2b1d\u2b1d\u2b1d\u001b[31;6H\u001b(B\u001b[m\u001b[1;8H\u001b[38;5;231m\u001b[48;5;233m   \u001b[3C                                                             \u001b[2;3H\u001b[48;5;232m                                                                              \u001b[3;8H\u001b[48;5;233m   \u001b[3C                                                   \u001b[4;6H\u001b[38;5;244m# Verify difficulty scaling\u001b[6;3H\u001b[38;5;232m\u2503\u001b[38;5;231m  \u001b[38;5;255m$ python3 -c \"\u001b[38;5;231m                                                             \u001b[7;6H\u001b[38;5;255mfrom shooter.spawner import SpawnPolicy\u001b[8;6Hsp = SpawnPolicy(cols=80, seed=0, base_interval=20, base_speed=4)\u001b[9;6Hassert sp._interval == 20 and sp._speed == 4\u001b[10;6Hsp.scale(0)\u001b[38;5;231m   \u001b[11;6H\u001b[38;5;255massert sp._interval == 20 and sp._speed == 4\u001b[12;8H.scale(25)\u001b[38;5;231m                                                     \u001b[13;6H\u001b[38;5;255m# 25 points => 1 step => interval *= 0.85,\u001b[Cspeed /= 1.10\u001b[14;6Hassert sp._interval == int(20 * 0.85), sp._interval\u001b[15;6H# \u001b[Cpeed /= 1.10 => 4/1.1\u001b[2C= 3.636... =>\u001b[Cround = 4, but base_speed/1.10 = 3.\u001b[16;6H63 -> round = 4\u001b[17;6Hprint('1 step:',\u001b[2Cp._interval, sp._speed)\u001b[38;5;231m               \u001b[18;6H\u001b[38;5;255msp.scale(100)\u001b[38;5;231m                                      \u001b[19;6H\u001b[38;5;255mprint('4 steps:', sp._interval, sp\u001b[C_speed)\u001b[38;5;231m                                 \u001b[20;6H\u001b[38;5;255mprint('scale smoke OK')\u001b[21;6H\"\u001b[38;5;231m                                        \u001b[22;6H             \u001b[23;6H\u001b[38;5;255m1 step: 17 4\u001b[38;5;231m                              \u001b[24;6H\u001b[38;5;255m4 steps: 10 3\u001b[38;5;231m          \u001b[25;6H\u001b[38;5;255mscale smoke OK\u001b[31;6H\u001b(B\u001b[m\u001b[35;4H\u001b[38;5;61m\u001b[48;5;232m\u25a0\u001b[38;5;239m\u25a0\u001b[38;5;237m\u25a0\u001b[38;5;235m\u25a0\u001b[38;5;60m\u2b1d\u2b1d\u2b1d\u2b1d\u001b[31;6H\u001b(B\u001b[m"]
